# Secrets only. Non-secret configuration (models, timeouts, queue names,
# provider chain, ...) lives in config.yaml.

GROQ_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

RABBITMQ_USER=bomcurriculo
RABBITMQ_PASSWORD=bomcurriculo

# Optional operational overrides of config.yaml, useful for per-environment
# deploys without editing the committed file.
# IA_PROVIDER=auto
# IA_PROVIDER_CHAIN=groq,gemini,deepseek,openai,ollama
# USAR_IA_PADRAO=true
# RABBITMQ_HOST=rabbitmq
# RABBITMQ_PORT=5672
# RABBITMQ_VHOST=/
# LOG_LEVEL=INFO
